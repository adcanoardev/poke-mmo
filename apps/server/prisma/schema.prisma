// apps/server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Usuarios y partida ────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  game           Game?
  trainerProfile TrainerProfile?
  combatTokens   CombatToken?
  inventory      Inventory[]
  structures     Structure[]
  creatures      CreatureInstance[]
  battleLogs     BattleLog[]
  mailMessages   MailMessage[]
  trainerItems   TrainerInventory[]
  equipment      EquipmentInstance[]
}

model Game {
  id        String   @id @default(cuid())
  seed      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  starterId Int
}

// ─── Perfil del entrenador ─────────────────────────────────────

model TrainerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  level    Int   @default(1)
  xp       Int   @default(0)
  prestige Int   @default(0)
  coins    Int   @default(0)
  medals   Int[] @default([])

  avatar             String?
  gender             String?
  onboardingComplete Boolean @default(false)

  // Monedas
  gold               Int      @default(0)
  diamonds           Int      @default(0)

  // Cosmético — validado siempre en servidor
  avatarFrame        String?
  unlockedFrames     String[] @default([])

  // Progresión Sanctums
  binderLevel        Int      @default(1)   // nivel del Binder (1-40), calculado desde xp
  sanctumClears      Int[]    @default([])  // índice i = nº victorias en Sanctum i

  // Nexus — Essences e invocación
  essences           Int      @default(0)
  goldEssences       Int      @default(0)   // Gold Essence — pool EPIC+ garantizado
  mythicEssences     Int      @default(0)   // reservado para futuro — desactivado en UI
  corruptedEssences  Int      @default(0)   // reservado para MYTHIC — desactivado en UI
  pityRare           Int      @default(0)   // aperturas consecutivas sin RARE+
  pityEpic           Int      @default(0)   // aperturas consecutivas sin EPIC+
  pityElite          Int      @default(0)   // aperturas consecutivas sin ELITE+
  pityLegendary      Int      @default(0)   // aperturas consecutivas sin LEGENDARY

  // Actividad
  lastSeen  DateTime @default(now())

  // Guild
  guildId   String?
  guildRole String?   // "Leader" | "Officer" | "Member"
  guild     Guild?    @relation(fields: [guildId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Nexus — Banner semanal ────────────────────────────────────

model NexusBanner {
  id             Int      @id @default(autoincrement())
  startsAt       DateTime
  endsAt         DateTime
  boostedMythIds String[] // speciesIds de myths con tasa aumentada
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
}

// ─── Guild ─────────────────────────────────────────────────────

model Guild {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String   @unique   // max 4 chars, uppercase
  banner      String   @default("#7b2fff")
  level       Int      @default(1)
  description String   @default("")
  leaderId    String   // userId del líder (denormalizado para lectura rápida)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  xp      Int @default(0)
  members TrainerProfile[]
  quests  GuildQuest[]
  messages GuildMessage[]
}

// ─── Guild Quests ───────────────────────────────────────────────

enum QuestType {
  WIN_BATTLES
  OPEN_ESSENCES
  COLLECT_MINE
  COMPLETE_SANCTUM
  WIN_PVP
}

model GuildQuest {
  id          String    @id @default(cuid())
  guildId     String
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  type        QuestType
  description String
  target      Int
  progress    Int       @default(0)
  date        String    // "YYYY-MM-DD" — reset diario
  reward50    String    @default("TOKENS")
  reward100   String    @default("TOKENS_GEMS")
  claimed50   String[]  @default([])  // userIds que reclamaron 50%
  claimed100  String[]  @default([])  // userIds que reclamaron 100%

  contributions GuildQuestContribution[]

  createdAt DateTime @default(now())
}

model GuildQuestContribution {
  id        String     @id @default(cuid())
  questId   String
  quest     GuildQuest @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId    String
  amount    Int
  createdAt DateTime   @default(now())
}

// ─── Guild Chat ─────────────────────────────────────────────────

model GuildMessage {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  username  String
  guildTag  String
  content   String
  createdAt DateTime @default(now())
}

// ─── Global Chat ────────────────────────────────────────────────

model GlobalMessage {
  id        String   @id @default(cuid())
  userId    String
  username  String
  guildTag  String   @default("")
  content   String
  createdAt DateTime @default(now())
}

// ─── Fichas de combate ─────────────────────────────────────────

model CombatToken {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  npcTokens Int @default(10)
  pvpTokens Int @default(5)

  lastNpcRecharge DateTime @default(now())
  lastPvpRecharge DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ─── Estructuras del rancho ────────────────────────────────────

model Structure {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type          StructureType
  level         Int           @default(1)
  lastCollected DateTime      @default(now())

  // Progresión de nivel
  structureXp   Int      @default(0)

  // Mina: cap de diamantes azules por día
  dailyDiamonds     Int      @default(0)
  lastDiamondReset  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

enum StructureType {
  MINE
  FORGE
  LAB
  NURSERY
}

// ─── Inventario ────────────────────────────────────────────────

model Inventory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  item     ItemType
  quantity Int      @default(0)

  @@unique([userId, item])
}

enum ItemType {
  SHARD
  CRYSTAL
  RUNE
  ELIXIR
  MEGA_ELIXIR
  GRAND_ELIXIR
  SPARK
  GRAND_SPARK
  EMBER_SHARD
  TIDE_SHARD
  VOLT_SHARD
  GROVE_SHARD
  FROST_SHARD
  BOND_CRYSTAL
  ASTRAL_SCALE
  IRON_COAT
  SOVEREIGN_STONE
  CIPHER_CORE
  BLUE_DIAMOND    // Mina → moneda futura de tienda (máx 15/día)
  ROCK_FRAGMENT   // Mina → material para subir nivel de Mina
  ARCANE_GEAR     // Lab  → material para subir nivel de Forge
  FLAME_CORE      // Forge → material para subir nivel de Nursery
}

// ─── Myths del jugador ────────────────────────────────────────

model CreatureInstance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  speciesId String
  nickname  String?
  level     Int     @default(1)
  xp        Int     @default(0)
  hp        Int
  maxHp     Int
  attack    Int
  defense   Int
  speed     Int
  accuracy  Int @default(100)
  critChance Int @default(15)
  critDamage Int @default(150)

  isInParty Boolean @default(false)
  slot      Int?

  obtainedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  inNursery Boolean @default(false)
}

// ─── BattleLog ────────────────────────────────────────────────

model BattleLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type              BattleType
  result            BattleResult
  xpGained          Int          @default(0)
  coinsGained       Int          @default(0)

  playerSpeciesId   String
  playerLevel       Int
  enemySpeciesId    String
  enemyLevel        Int
  capturedSpeciesId String?

  createdAt DateTime @default(now())
}

enum BattleType {
  NPC
  PVP
}

enum BattleResult {
  WIN
  LOSE
  DRAW
}

// ─── MailBox ───────────────────────────────────────────────────

enum MailType {
  SYSTEM   // recompensas automáticas, resultados PvP, reset semanal
  GUILD    // invitaciones, solicitudes de unión (para GM/Officers)
  PROMO    // códigos promocionales, noticias
}

model MailMessage {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        MailType  @default(SYSTEM)
  title       String
  body        String
  isRead      Boolean   @default(false)
  claimedAt   DateTime?
  expiresAt   DateTime  // 7 días por defecto al crear
  createdAt   DateTime  @default(now())

  // Adjuntos reclamables: { gold, diamonds, essences, goldEssences, items: [{itemSlug, qty}] }
  attachments Json?
  // Datos para botones de acción especiales (accept guild request, etc.)
  actionData  Json?
}

// ─── Sistema de Ítems ──────────────────────────────────────────

enum ItemCategory {
  EQUIPMENT    // Weapon, Armor, Accessory
  CONSUMABLE   // HP Potion, Revive, Boost Scroll, Shield Orb
  ESSENCE      // Purple Essence, Gold Essence
  MATERIAL     // Forge Stone, Crystal Shard, Ancient Rune
  KEY          // Ruins Key, Tower Key
  BOOSTER      // XP Booster, Gold Booster
}

model Item {
  id          Int          @id @default(autoincrement())
  slug        String       @unique  // "hp_potion", "forge_stone", etc.
  name        String
  description String       @default("")
  category    ItemCategory
  rarity      String       @default("COMMON")  // COMMON|RARE|EPIC|LEGENDARY
  iconUrl     String       @default("")
  isActive    Boolean      @default(true)

  createdAt   DateTime     @default(now())

  trainerItems TrainerInventory[]
}

// Inventario de ítems no-equipamiento (consumibles, materiales, keys, boosters, essences)
model TrainerInventory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id])
  quantity  Int      @default(1)

  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
}

// Instancias de equipamiento (cada pieza tiene sus propios stats)
model EquipmentInstance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId    Int      // referencia al template del ítem (Item.id)
  level     Int      @default(1)   // 1–12
  rarity    String   @default("COMMON")

  // Stat principal (fijo, nunca cambia al subir nivel)
  mainStat  String   // "ATK_PCT" | "DEF_PCT" | "HP_PCT" | "SPD" | "CRIT_RATE" | "CRIT_DMG"
  mainValue Float

  // Stats secundarios (se desbloquean/mejoran en niveles 4, 8, 12)
  subStat1  String?  subValue1 Float?
  subStat2  String?  subValue2 Float?
  subStat3  String?  subValue3 Float?

  // null = en inventario, cuid = myth que lo lleva equipado
  equippedOn String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
