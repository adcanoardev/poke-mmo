generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Usuarios y partida (existentes) ──────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  game           Game?
  trainerProfile TrainerProfile?
  combatTokens   CombatToken?
  inventory      Inventory[]
  structures     Structure[]
  creatures      CreatureInstance[]
  battleLogs     BattleLog[]
}

model Game {
  id        String   @id @default(cuid())
  seed      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  starterId Int
}

// ─── Perfil del entrenador ─────────────────────────────────────
model TrainerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  level    Int   @default(1)
  xp       Int   @default(0)
  prestige Int   @default(0)
  coins    Int   @default(0)
  medals   Int[] @default([])

  // Onboarding
  avatar             String?
  gender             String?
  onboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Fichas de combate ─────────────────────────────────────────

model CombatToken {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  npcTokens Int @default(10) // máx 10
  pvpTokens Int @default(5) // máx 5

  lastNpcRecharge DateTime @default(now())
  lastPvpRecharge DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ─── Estructuras del rancho ────────────────────────────────────

model Structure {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type          StructureType
  level         Int           @default(1)
  lastCollected DateTime      @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

enum StructureType {
  MINE
  POKEBALL_FACTORY
  LAB
  NURSERY
}

// ─── Inventario ────────────────────────────────────────────────

model Inventory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  item     ItemType
  quantity Int      @default(0)

  @@unique([userId, item])
}

enum ItemType {
  POKEBALL
  SUPERBALL
  ULTRABALL
  MASTERBALL
  POTION
  SUPER_POTION
  HYPER_POTION
  REVIVE
  MAX_REVIVE
  FIRE_STONE
  WATER_STONE
  THUNDER_STONE
  LEAF_STONE
  ICE_STONE
  LINK_CABLE
  DRAGON_SCALE
  METAL_COAT
  KINGS_ROCK
  UPGRADE
}

// ─── Myths del jugador ───────────────────────────────────────

model CreatureInstance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  speciesId String
  nickname  String?
  level     Int     @default(1)
  xp        Int     @default(0)
  hp        Int
  maxHp     Int
  attack    Int
  defense   Int
  speed     Int

  isInParty Boolean @default(false)
  slot      Int?

  caughtAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Battletag ───────────────────────────────────────
model BattleLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type              BattleType
  result            BattleResult
  xpGained          Int          @default(0)
  coinsGained       Int          @default(0)
  
  playerSpeciesId   String
  playerLevel       Int
  enemySpeciesId    String
  enemyLevel        Int
  capturedSpeciesId String?

  createdAt DateTime @default(now())
}

enum BattleType {
  NPC
  PVP
}

enum BattleResult {
  WIN
  LOSE
  DRAW
}
