// apps/server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Usuarios y partida ────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  game           Game?
  trainerProfile TrainerProfile?
  combatTokens   CombatToken?
  inventory      Inventory[]
  structures     Structure[]
  creatures      CreatureInstance[]
  battleLogs     BattleLog[]
}

model Game {
  id        String   @id @default(cuid())
  seed      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  starterId Int
}

// ─── Perfil del entrenador ─────────────────────────────────────

model TrainerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  level    Int   @default(1)
  xp       Int   @default(0)
  prestige Int   @default(0)
  coins    Int   @default(0)
  medals   Int[] @default([])

  avatar             String?
  gender             String?
  onboardingComplete Boolean @default(false)

  // Monedas
  gold               Int      @default(0)
  diamonds           Int      @default(0)

  // Cosmetico - validado siempre en servidor
  avatarFrame        String   @default("none")
  unlockedFrames     String[] @default([])

  // Progresión Sanctums
  binderLevel        Int      @default(1)   // nivel del Binder (1-40), calculado desde xp
  sanctumClears      Int[]    @default([])  // índice i = nº victorias en Sanctum i

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Fichas de combate ─────────────────────────────────────────

model CombatToken {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  npcTokens Int @default(10)
  pvpTokens Int @default(5)

  lastNpcRecharge DateTime @default(now())
  lastPvpRecharge DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ─── Estructuras del rancho ────────────────────────────────────

model Structure {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type          StructureType
  level         Int           @default(1)
  lastCollected DateTime      @default(now())

  // Progresión de nivel
  structureXp   Int      @default(0)  // XP acumulada hacia el siguiente nivel
  
  // Mina: cap de diamantes azules por día
  dailyDiamonds     Int      @default(0)  // cuántos diamantes se han recogido hoy
  lastDiamondReset  DateTime @default(now()) // cuando se reinicia el contador diario

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

enum StructureType {
  MINE
  FRAGMENT_FORGE
  LAB
  NURSERY
}

// ─── Inventario ────────────────────────────────────────────────

model Inventory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  item     ItemType
  quantity Int      @default(0)

  @@unique([userId, item])
}

enum ItemType {
  FRAGMENT
  SHARD
  CRYSTAL
  RUNE
  ELIXIR
  MEGA_ELIXIR
  GRAND_ELIXIR
  SPARK
  GRAND_SPARK
  EMBER_SHARD
  TIDE_SHARD
  VOLT_SHARD
  GROVE_SHARD
  FROST_SHARD
  BOND_CRYSTAL
  ASTRAL_SCALE
  IRON_COAT
  SOVEREIGN_STONE
  CIPHER_CORE
  // ─── Nuevos materiales de progresión ───
  BLUE_DIAMOND    // Mina → moneda futura de tienda (máx 15/día)
  ROCK_FRAGMENT   // Mina → material para subir nivel de Mina
  ARCANE_GEAR     // Lab  → material para subir nivel de Forja
  FLAME_CORE      // Forja → material para subir nivel de Guardería
}

// ─── Myths del jugador ────────────────────────────────────────

model CreatureInstance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  speciesId String
  nickname  String?
  level     Int     @default(1)
  xp        Int     @default(0)
  hp        Int
  maxHp     Int
  attack    Int
  defense   Int
  speed     Int
  accuracy  Int @default(100)  // Precisión base (0-100). 100 = nunca falla.
  critChance Int @default(15)  // % probabilidad de golpe crítico (0-100)
  critDamage Int @default(150) // Multiplicador crítico base. 150 = ×1.5. Fórmula escalable.

  isInParty Boolean @default(false)
  slot      Int?

  obtainedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  inNursery Boolean @default(false)
}

// ─── BattleLog ────────────────────────────────────────────────

model BattleLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type              BattleType
  result            BattleResult
  xpGained          Int          @default(0)
  coinsGained       Int          @default(0)

  playerSpeciesId   String
  playerLevel       Int
  enemySpeciesId    String
  enemyLevel        Int
  capturedSpeciesId String?

  createdAt DateTime @default(now())
}

enum BattleType {
  NPC
  PVP
}

enum BattleResult {
  WIN
  LOSE
  DRAW
}
